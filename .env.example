# Shared server-side environment.
# Loaded automatically by @enxoval/env/server for apps/api and packages/db.
# Mobile-side variables (EXPO_PUBLIC_*) live in apps/mobile/.env*.

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgres://neondb_owner:CHANGE_ME@ep-xxx.sa-east-1.aws.neon.tech:5432/neondb?sslmode=require"

# ── Better Auth ──────────────────────────────────────────────
BETTER_AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3004"
TRUSTED_ORIGINS="enxoval://,http://localhost:8081"

# ── Pusher (server-side) ─────────────────────────────────────
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="sa1"

# ── Expo push notifications ──────────────────────────────────
EXPO_ACCESS_TOKEN=""

# ── App config ───────────────────────────────────────────────
PORT=3004
