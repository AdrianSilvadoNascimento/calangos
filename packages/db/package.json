{
  "name": "@enxoval/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:reset": "tsx --env-file=.env src/reset.ts"
  },
  "dependencies": {
    "@enxoval/env": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "postgres": "^3.4.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@enxoval/config-ts": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.30.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
